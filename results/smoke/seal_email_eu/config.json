{
  "dataset": {
    "path": "data/processed/email_eu/edges.csv",
    "type": "email_eu"
  },
  "eval": {
    "degree_bins": 50,
    "graph_every_n": 1,
    "k_list": [
      1,
      3,
      5,
      10
    ]
  },
  "feedback": {
    "cooldown_mode": "decay",
    "cooldown_rounds": 5,
    "p_neg": 0.0,
    "p_pos": 1.0
  },
  "init_edge_ratio": 0.6,
  "init_strategy": "random",
  "model": {
    "hidden_dim": 32,
    "label_dim": 16,
    "num_layers": 3,
    "type": "seal"
  },
  "recall": {
    "method": "two_hop_bidir_random",
    "top_k_recall": 100
  },
  "recommend": {
    "cold_start_random_fill": true,
    "top_k": 10
  },
  "replay": {
    "capacity": 0,
    "sample_n": 0
  },
  "runtime": {
    "device": "cuda",
    "log_every": 1,
    "out_dir": "results/smoke/seal_email_eu",
    "seed": 42
  },
  "total_rounds": 1,
  "trainer": {
    "batch_subgraph_max_hop": 2,
    "grad_clip": 1.0,
    "lr": 5e-05,
    "max_neighbors": 30,
    "min_batch_size": 4,
    "scheduler": {
      "strategy": "constant"
    },
    "update_every_n_rounds": 1
  },
  "user_selector": {
    "sample_ratio": 0.1,
    "strategy": "uniform"
  }
}
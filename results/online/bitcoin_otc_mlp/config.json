{
  "dataset": {
    "path": "data/processed/bitcoin_otc/edges.csv",
    "type": "bitcoin_otc"
  },
  "eval": {
    "degree_bins": 50,
    "graph_every_n": 10,
    "k_list": [
      5,
      10,
      20
    ]
  },
  "feedback": {
    "cooldown_mode": "decay",
    "cooldown_rounds": 5,
    "p_neg": 0.02,
    "p_pos": 0.8
  },
  "init_edge_ratio": 0.05,
  "init_strategy": "stratified",
  "model": {
    "hidden_dim": 64,
    "type": "mlp"
  },
  "recall": {
    "components": [
      {
        "name": "adamic_adar",
        "top_k": 30
      },
      {
        "alpha": 0.15,
        "name": "ppr",
        "top_k": 10
      },
      {
        "name": "community_random",
        "top_k": 10
      }
    ],
    "method": "mixture",
    "top_k_recall": 50
  },
  "recommend": {
    "cold_start_random_fill": true,
    "top_k": 10
  },
  "replay": {
    "capacity": 500,
    "sample_n": 64
  },
  "runtime": {
    "device": "cuda",
    "log_every": 1,
    "out_dir": "results/online/bitcoin_otc_mlp",
    "seed": 42
  },
  "total_rounds": 100,
  "trainer": {
    "lr": 0.001,
    "scheduler": {
      "cycle_rounds": 25,
      "min_lr": 1e-05,
      "strategy": "cyclic",
      "warmup_rounds": 5
    },
    "update_every_n_rounds": 1
  },
  "user_selector": {
    "alpha": 0.5,
    "beta": 2.0,
    "gamma": 2.0,
    "lam": 0.1,
    "sample_ratio": 0.1,
    "strategy": "composite",
    "w": 3
  }
}
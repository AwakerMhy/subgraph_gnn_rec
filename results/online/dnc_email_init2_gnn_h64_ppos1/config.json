{
  "dataset": {
    "path": "data/processed/dnc_email/edges.csv",
    "type": "dnc_email"
  },
  "eval": {
    "degree_bins": 50,
    "graph_every_n": 10,
    "k_list": [
      1,
      3,
      5
    ]
  },
  "feedback": {
    "cooldown_mode": "decay",
    "cooldown_rounds": 5,
    "p_neg": 0.0,
    "p_pos": 1.0
  },
  "init_edge_ratio": 0.2,
  "init_strategy": "stratified",
  "model": {
    "encoder_type": "last",
    "hidden_dim": 64,
    "node_feat_dim": 0,
    "num_layers": 3,
    "type": "gnn"
  },
  "recall": {
    "components": [
      {
        "name": "two_hop_random",
        "top_k": 70
      },
      {
        "alpha": 0.15,
        "name": "ppr_nodes",
        "top_k": 30
      }
    ],
    "method": "mixture",
    "top_k_recall": 100
  },
  "recommend": {
    "cold_start_random_fill": true,
    "top_k": 5
  },
  "replay": {
    "capacity": 200,
    "sample_n": 32
  },
  "runtime": {
    "device": "cuda",
    "log_every": 1,
    "out_dir": "results/online/dnc_email_init2_gnn_h64_ppos1",
    "seed": 42
  },
  "total_rounds": 100,
  "trainer": {
    "batch_subgraph_max_hop": 2,
    "grad_clip": 1.0,
    "lr": 0.001,
    "max_neighbors": 30,
    "min_batch_size": 4,
    "scheduler": {
      "strategy": "constant"
    },
    "score_chunk_size": 512,
    "update_every_n_rounds": 1,
    "use_amp": true
  },
  "user_selector": {
    "alpha": 0.5,
    "beta": 2.0,
    "gamma": 2.0,
    "lam": 0.1,
    "sample_ratio": 0.1,
    "strategy": "composite",
    "w": 3
  }
}
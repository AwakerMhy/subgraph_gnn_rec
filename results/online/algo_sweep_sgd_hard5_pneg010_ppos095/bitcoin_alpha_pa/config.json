{
  "dataset": {
    "path": "data/processed/bitcoin_alpha/edges.csv",
    "type": "bitcoin_alpha"
  },
  "eval": {
    "degree_bins": 50,
    "graph_every_n": 10,
    "k_list": [
      1,
      3,
      5,
      10
    ]
  },
  "feedback": {
    "cooldown_mode": "hard",
    "cooldown_rounds": 5,
    "p_neg": 0.1,
    "p_pos": 0.95
  },
  "init_edge_ratio": 0.25,
  "init_strategy": "stratified",
  "model": {
    "type": "pa"
  },
  "recall": {
    "method": "two_hop_random",
    "top_k_recall": 100
  },
  "recommend": {
    "cold_start_random_fill": true,
    "top_k": 10
  },
  "replay": {
    "capacity": 0,
    "sample_n": 0
  },
  "runtime": {
    "device": "cpu",
    "log_every": 50,
    "seed": 42,
    "out_dir": "results/online/algo_sweep_sgd_hard5_pneg010_ppos095/bitcoin_alpha_pa"
  },
  "total_rounds": 100,
  "trainer": {
    "batch_subgraph_max_hop": 2,
    "grad_clip": 1.0,
    "lr": 0.01,
    "optimizer": "sgd",
    "momentum": 0.9,
    "max_neighbors": 30,
    "min_batch_size": 4,
    "scheduler": {
      "min_lr": 1e-05,
      "strategy": "cosine_warmup",
      "warmup_rounds": 5
    },
    "update_every_n_rounds": 1
  },
  "user_selector": {
    "alpha": 0.5,
    "beta": 2.0,
    "gamma": 2.0,
    "lam": 0.1,
    "sample_ratio": 0.1,
    "strategy": "composite",
    "w": 3
  }
}